Step 4: Push to GitHub
bash
git remote add origin https://github.com/divineshedrack33220/brimble-pipeline.git
git branch -M main
git push -u origin main
Step 5: Create render.yaml for Render deployment
bash
cat > render.yaml << 'EOF'
services:
  - type: web
    name: brimble-backend
    runtime: docker
    repo: https://github.com/divineshedrack33220/brimble-pipeline
    plan: free
    dockerContext: ./backend
    dockerfilePath: ./backend/Dockerfile
    envVars:
      - key: NODE_ENV
        value: production
      - key: PORT
        value: 3000

  - type: web
    name: brimble-frontend
    runtime: docker
    repo: https://github.com/divineshedrack33220/brimble-pipeline
    plan: free
    dockerContext: ./frontend
    dockerfilePath: ./frontend/Dockerfile
    envVars:
      - key: VITE_API_URL
        value: https://brimble-backend.onrender.com
EOF
Step 6: Push the render.yaml file
bash
git add render.yaml
git commit -m "Add Render deployment configuration"
git push
Step 7: Deploy to Render
For Backend:
Go to https://dashboard.render.com

Click "New +" → "Web Service"

Connect your GitHub repository

Select brimble-backend as service name

Select "Docker" as runtime

Set:

Root Directory: ./backend

Dockerfile Path: ./backend/Dockerfile

Click "Create Web Service"

For Frontend:
Click "New +" → "Web Service" again

Select same repository

Name: brimble-frontend

Select "Docker" as runtime

Set:

Root Directory: ./frontend

Dockerfile Path: ./frontend/Dockerfile

Add environment variable:

VITE_API_URL = https://brimble-backend.onrender.com

Click "Create Web Service"

Alternative: Deploy using Render CLI
bash
# Install Render CLI (if not installed)
npm install -g @render/cli

# Login
render login

# Deploy backend
render deploy --service brimble-backend

# Deploy frontend
render deploy --service brimble-frontend
Step 8: Update frontend API URL for production
bash
cd ~/OneDrive/Desktop/brimble-pipeline/frontend
Update the API base URL in src/App.tsx:

bash
cat > src/App.tsx << 'EOF'
// ... other imports
// Replace the API base URL based on environment
const API_BASE_URL = import.meta.env.PROD 
  ? 'https://brimble-backend.onrender.com/api'
  : 'http://localhost:3000/api';

const API = axios.create({ baseURL: API_BASE_URL });
// ... rest of the code
EOF
